# Copy to .env and fill in values. Never commit .env.

# Backend (Railway/Render or local)
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# Cloudinary (vitals video upload; frontend config)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Auth0 (SPA; also exposed via /frontend-config)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=

# Backboard (intake / routing)
BACKBOARD_API_KEY=
BACKBOARD_BASE_URL=https://app.backboard.io/api
BACKBOARD_ASSISTANT_ID=
BACKBOARD_ASSISTANT_ID_DERMATOLOGY=

# ElevenLabs (TTS/STT)
ELEVENLABS_API_KEY=

# Presage (vitals from video)
PRESAGE_API_KEY=

# Supabase (health profiles; required for GET/PUT /profile/health)
SUPABASE_URL=
SUPABASE_KEY=

# Optional: Gemini (if used)
GEMINI_API_KEY=

# Frontend build (Vite) – used at build time for Auth0
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
